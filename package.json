{
  "name": "metropol-theater",
  "version": "1.0.0",
  "description": "Metropol-Theater Brunsbüttel Website",
  "scripts": {
    "dev": "npx tailwindcss -i ./src/css/main.css -o ./assets/css/tailwind.css --watch",
    "build": "npx tailwindcss -i ./src/css/main.css -o ./assets/css/tailwind.css --minify",
    "lint": "prettier --write 'src/**/*.{css,js}'",
    "serve": "php -S localhost:8000 kirby/router.php",
    "start": "php -S localhost:8000 kirby/router.php"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.3.3"
  }
}
